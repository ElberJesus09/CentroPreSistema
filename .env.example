APP_NAME=CPU-UNPRG
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
# Render:
# APP_ENV=production
# APP_URL=https://tu-servicio.onrender.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Render:
# LOG_CHANNEL=stderr

DB_CONNECTION=sqlite
# Render/PostgreSQL:
# DB_CONNECTION=pgsql
# DATABASE_URL=postgres://usuario:password@host:5432/base_de_datos

# Modelo autenticable (staff)
AUTH_MODEL=App\Models\Staff

# Contrasena inicial del usuario superadmin (cambiar en produccion)
SUPERADMIN_INITIAL_PASSWORD=
# Render: define este valor solo la primera vez que necesites crear/inicializar el superadmin.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Resend (sin dominio verificado): solo puede enviar a la cuenta con la que se registro en Resend.
# Para enviar a cualquier alumno: verificar dominio en https://resend.com/domains y usar MAIL_FROM_ADDRESS de ese dominio.

# Opcional: cola futura para correos de inscripcion (requiere worker)
STUDENT_REGISTRATION_MAIL_QUEUE=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
